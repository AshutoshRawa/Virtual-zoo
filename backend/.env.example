# =========================================
# Virtual Zoo — Environment Variables
# =========================================
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to git.
# =========================================

NODE_ENV=development
PORT=5001

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com/ → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# JWT Secret — use a long, random string (min 32 characters)
JWT_SECRET=replace_with_a_strong_random_secret_key
